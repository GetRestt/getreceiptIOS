platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}
# ... (standard flutter_root and plugin setup)
target 'Runner' do
  use_frameworks! :linkage => :static
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  # ... (your pod declarations)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # FIX: Explicitly allow non-modular headers for all pods to satisfy Xcode 15/16
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end

    # Specific fix for flutter_web_auth_2
    if target.name == 'flutter_web_auth_2'
      target.build_configurations.each do |config|
        config.build_settings['USE_FRAMEWORKS'] = 'YES'
        config.build_settings['LINKAGE'] = 'static'
      end
    end
  end
end
